# ── Ollama (local, M4 MacBook) ────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:latest

# ── Whisper STT server ────────────────────────────────────────────────────────
WHISPER_URL=http://localhost:8001

# ── Email alerts (Gmail SMTP) ─────────────────────────────────────────────────
# Gmail setup: Google Account → Security → 2-Step Verification → App Passwords
# Create an App Password for "Mail" and paste the 16-char code below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx

# ── Gemini fallback (optional) ────────────────────────────────────────────────
# Only used if Ollama is unreachable. Get a free key at https://aistudio.google.com
# GEMINI_API_KEY=AIza...
